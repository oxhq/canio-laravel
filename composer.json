{
  "name": "oxhq/canio",
  "description": "Browser-grade PDF and document rendering for Laravel powered by Stagehand",
  "type": "library",
  "license": "MIT",
  "homepage": "https://oxhq.github.io/canio/",
  "keywords": [
    "laravel",
    "pdf",
    "documents",
    "chromium",
    "stagehand",
    "browser-rendering",
    "high-fidelity"
  ],
  "authors": [
    {
      "name": "David Garay",
      "email": "garaekz@gmail.com"
    }
  ],
  "support": {
    "docs": "https://oxhq.github.io/canio/",
    "issues": "https://github.com/oxhq/canio/issues",
    "source": "https://github.com/oxhq/canio"
  },
  "require": {
    "php": "^8.2",
    "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/filesystem": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
    "symfony/process": "^6.4|^7.0|^8.0"
  },
  "require-dev": {
    "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
    "pestphp/pest": "^2.34|^3.8|^4.0",
    "pestphp/pest-plugin-laravel": "^2.4|^3.2|^4.0",
    "laravel/pint": "^1.23"
  },
  "autoload": {
    "psr-4": {
      "Oxhq\\Canio\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Oxhq\\Canio\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "pest",
    "format": "pint"
  },
  "extra": {
    "laravel": {
      "providers": [
        "Oxhq\\Canio\\CanioServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
